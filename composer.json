{
    "name": "bobkosse/laravel-data-security",
    "description": "Easy to use data security solution for Laravel",
    "type": "library",
    "authors": [
        {
            "name": "Bob Kosse",
            "email": "bob@bobkosse.nl"
        }
    ],
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "orchestra/testbench": "^11.1",
        "pestphp/pest": "^4.5"
    },
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "BobKosse\\DataSecurity\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "BobKosse\\DataSecurity\\DataSecurityServiceProvider"
            ]
        }
    }
}
